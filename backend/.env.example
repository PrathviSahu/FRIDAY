# Copy this file to backend/.env and insert your Twelve Data API key.
# Get a free key at https://twelvedata.com/pricing
TWELVE_DATA_API_KEY=your_key_here

# Gemini API key for speech-to-text (voice commands). Get one at
# https://aistudio.google.com/apikey — used by backend/services/stt.py
GEMINI_API_KEY=your_key_here
GEMINI_MODEL=gemini-2.0-flash
